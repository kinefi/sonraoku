{
  "name": "sonraoku",
  "version": "0.1.0",
  "main": "index.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kinefi/sonraoku.git"
  },
  "bugs": {
    "url": "https://github.com/kinefi/sonraoku/issues",
    "email": "toplumbilisim+sonraoku@gmail.com"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "expo start",
    "fix": "expo install --fix",
    "android": "expo start --android",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "doctor": "npx expo-doctor",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "build:android": "eas build --platform android --non-interactive",
    "build:android:local": "GRADLE_OPTS='-Dorg.gradle.daemon=true -Dorg.gradle.parallel=true' eas build --platform android --local --profile preview",
    "build:apk": "eas build --platform android --profile preview",
    "build:all": "eas build --platform all --non-interactive",
    "submit:android": "eas submit --platform android",
    "release": "commit-and-tag-version"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@mozilla/readability": "^0.6.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.99.0",
    "drizzle-orm": "^0.45.2",
    "expo": "~55.0.15",
    "expo-background-fetch": "~55.0.14",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.14",
    "expo-crypto": "^55.0.14",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "^55.0.14",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-speech": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "expo-task-manager": "~55.0.14",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "~4.2.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "~55.0.0",
    "commit-and-tag-version": "^12.5.0",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-dev-client": "~55.0.27",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0"
}
