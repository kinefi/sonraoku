minimum-release-age=0
overrides[esbuild]=0.25.0
# Consolidate TanStack versions to prevent fragmentation between query-core and react-query
overrides[@tanstack/react-query]=5.62.3
overrides[@tanstack/query-core]=5.62.3

# Optimization: Hoist essential Expo/React Native packages for native build compatibility
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*babel*
public-hoist-pattern[]=*types*